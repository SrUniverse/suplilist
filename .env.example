# SupliList — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env real

# Afiliados (necessário para links de compra com tracking)
# Amazon: https://associates.amazon.com.br → Registre e obtenha seu Associate ID (formato: nome-20)
# Mercado Livre: https://www.mercadolivre.com.br/jm/affiliates → Partner ID
# Shopee: https://seller.shopee.com.br → Affiliate Program
VITE_AMAZON_AFFILIATE_ID=suplilist01-20
VITE_ML_AFFILIATE_ID=
VITE_SHOPEE_AFFILIATE_ID=

# Push Notifications (Firebase Cloud Messaging)
FCM_SERVER_KEY=
VITE_FCM_VAPID_KEY=

# Analytics (opcional)
VITE_GA_MEASUREMENT_ID=

# Ambiente
NODE_ENV=development
