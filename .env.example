# SupliList — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env real no repositório

# ══════════════════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════

# Environment: development, staging, production
NODE_ENV=development

# Server port
PORT=5000

# ══════════════════════════════════════════════════════════════════════════════
# CORS POLICY - Explicit Domain Whitelist
# ══════════════════════════════════════════════════════════════════════════════

# Development frontend URL
# Used for local development and testing
CORS_ORIGIN_DEV=http://localhost:5173

# Production frontend URL
# Used only when NODE_ENV=production or explicitly configured
CORS_ORIGIN_PROD=https://suplilist.app

# Additional custom origins (optional, comma-separated)
# Example: CORS_ORIGINS=https://custom-domain.com,https://another-domain.com
CORS_ORIGINS=

# ══════════════════════════════════════════════════════════════════════════════
# DATABASE - PostgreSQL
# ══════════════════════════════════════════════════════════════════════════════

# Full connection string (takes precedence if set)
DATABASE_URL=postgresql://suplilist:suplilist_dev@localhost:5432/suplilist

# Individual connection parameters (used if DATABASE_URL not set)
POSTGRES_USER=suplilist
POSTGRES_PASSWORD=suplilist_dev
POSTGRES_DB=suplilist
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ══════════════════════════════════════════════════════════════════════════════
# CACHE - Redis
# ══════════════════════════════════════════════════════════════════════════════

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# ══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION - JWT
# ══════════════════════════════════════════════════════════════════════════════

# JWT Secret (min 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-min-32-characters-change-in-production

# JWT token expiration time
JWT_EXPIRES_IN=24h

# Refresh token secret (min 32 characters)
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-chars-in-production

# Refresh token expiration time
REFRESH_TOKEN_EXPIRES_IN=7d

# ══════════════════════════════════════════════════════════════════════════════
# OAUTH - Google
# ══════════════════════════════════════════════════════════════════════════════

# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ══════════════════════════════════════════════════════════════════════════════
# FILE STORAGE - AWS S3
# ══════════════════════════════════════════════════════════════════════════════

# AWS Access Key ID (for S3 uploads)
AWS_ACCESS_KEY_ID=

# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=

# S3 Bucket name (for user avatars, etc.)
AWS_S3_BUCKET=

# AWS Region (default: us-east-1)
AWS_S3_REGION=us-east-1

# ══════════════════════════════════════════════════════════════════════════════
# EMAIL SERVICE - Resend
# ══════════════════════════════════════════════════════════════════════════════

# Get from: https://resend.com/
RESEND_API_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# AFFILIATE PROGRAMS
# ══════════════════════════════════════════════════════════════════════════════

# Amazon Associates ID
# Get from: https://associates.amazon.com.br
# Format: name-20 (example: suplilist01-20)
VITE_AMAZON_AFFILIATE_ID=suplilist01-20

# Mercado Livre Partner ID
# Get from: https://www.mercadolivre.com.br/jm/affiliates
VITE_ML_AFFILIATE_ID=

# Shopee Affiliate Program
# Get from: https://seller.shopee.com.br
VITE_SHOPEE_AFFILIATE_ID=

# ══════════════════════════════════════════════════════════════════════════════
# NOTIFICATIONS - Firebase Cloud Messaging
# ══════════════════════════════════════════════════════════════════════════════

# FCM Server Key (for backend push notifications)
FCM_SERVER_KEY=

# FCM VAPID Key (for frontend push notifications)
VITE_FCM_VAPID_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# ANALYTICS
# ══════════════════════════════════════════════════════════════════════════════

# Google Analytics Measurement ID
# Get from: https://analytics.google.com/
VITE_GA_MEASUREMENT_ID=

# ══════════════════════════════════════════════════════════════════════════════
# DEVELOPMENT ONLY
# ══════════════════════════════════════════════════════════════════════════════

# Enable debug logging (development only)
DEBUG=suplilist:*

# Skip email verification in development
SKIP_EMAIL_VERIFICATION=false
