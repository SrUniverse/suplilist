# SupliList — Environment Variables
# Copy to .env and fill in the values before running locally.
# NEVER commit the real .env file.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/suplilist?retryWrites=true&w=majority

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-with-another-random-string-min-32-chars

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Vercel Cron ───────────────────────────────────────────────────────────────
CRON_SECRET=replace-with-random-secret

# ── Prometheus metrics (leave empty to disable /metrics endpoint) ─────────────
METRICS_TOKEN=replace-with-random-token

# ── Sentry (optional) ────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN_DEV=http://localhost:5173
CORS_ORIGIN_PROD=https://suplilist.app

# ── Cloudflare Edge Token (optional) ─────────────────────────────────────────
CF_EDGE_TOKEN=

# ── Frontend (Vite) — add to frontend/.env.local ─────────────────────────────
# VITE_API_BASE_URL=http://localhost:5000
