{
  "name": "SupliList - Rastreador de Suplementação",
  "short_name": "SupliList",
  "description": "App inteligente para acompanhar sua aderência à suplementação com lembretes, relatórios e análises.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "theme_color": "#007AFF",
  "background_color": "#FFFFFF",
  "categories": ["health", "productivity"],
  "screenshots": [
    {
      "src": "/assets/screenshot1.png",
      "sizes": "540x720",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Dashboard de Aderência"
    },
    {
      "src": "/assets/screenshot2.png",
      "sizes": "540x720",
