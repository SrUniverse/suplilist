{
  "installCommand": "npm install",
  "buildCommand": "vite build && node ../scripts/prerender.cjs",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://suplilist-api.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}