{
  "name": "suplilist",
  "private": true,
  "workspaces": [
    "frontend",
    "server",
    "shared"
  ],
  "scripts": {
    "dev":           "npm run dev -w @suplilist/frontend",
    "build":         "npm run build -w @suplilist/frontend",
    "test":          "npm run test -w @suplilist/frontend",
    "test:server":   "npm run test -w @suplilist/server",
    "test:coverage": "npm run test:coverage -w @suplilist/frontend",
    "test:e2e":      "playwright test",
    "lint:css":      "npm run lint:css -w @suplilist/frontend",
    "lint:js":       "npm run lint:js -w @suplilist/frontend",
    "perf:lighthouse": "lighthouse-ci",
    "test:a11y": "axe-cli http://127.0.0.1:8080 --exit"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "wait-on": "^8.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
