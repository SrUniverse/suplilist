    "postcss": "^8.4.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "fuse.js": "^7.3.0"
  }
