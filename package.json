{
  "name": "suplilist",
  "version": "2.0.0",
  "description": "Guia de suplementação fitness",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/prerender.cjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "npm run test:e2e -- --grep '@accessibility'",
    "test:mobile": "npm run test:e2e -- --grep '@mobile'",
    "perf:lighthouse": "lighthouse-ci",
    "perf:report": "npm run build && npm run perf:lighthouse",
    "build:audit": "npx live-server dist/ --port=8080 --no-browser & vite build",
    "lint:css": "npx stylelint 'src/css/**/*.css'",
    "lint:js": "eslint src/"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "fuse.js": "^7.3.0"
  }
}
