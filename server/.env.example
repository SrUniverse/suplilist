# SupliList Server — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_VERSION=1.0.0

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/suplilist
MONGO_TEST_URI=mongodb://localhost:27017/suplilist_test

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URI=redis://localhost:6379

# ── Auth & Encryption ─────────────────────────────────────────────────────────
ENCRYPTION_KEY=            # 32-byte hex string — generate with: openssl rand -hex 32
BCRYPT_SALT_ROUNDS=12
GOOGLE_CLIENT_ID=          # OAuth2 client ID from Google Cloud Console

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=            # https://resend.com
EMAIL_FROM=noreply@suplilist.com.br

# ── Storage (AWS S3 / Cloudflare R2) ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=suplilist
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=          # Cloudflare R2: https://<account>.r2.cloudflarestorage.com
CF_EDGE_TOKEN=             # Cloudflare CDN token (optional)

# ── Firecrawl (web scraping) ──────────────────────────────────────────────────
# Get your key at https://www.firecrawl.dev
# ROTATE IMMEDIATELY if this key is ever exposed.
FIRECRAWL_API_KEY=

# ── Affiliate codes ───────────────────────────────────────────────────────────
# Amazon Associates tag — appended as ?tag=<value> to all amazon.com.br URLs.
AFFILIATE_CODE_AMAZON=suplilist01-20

# Mercado Livre affiliate ID (matt_tool from the portal-generated link).
# Value: 35217033 (matt_word=suplilist)
# NOTE: crediting requires API-generated links, not a URL param append.
AFFILIATE_CODE_MERCADOLIVRE=matt:suplilist:35217033

# Shopee App ID for generateShortLink Affiliate API.
# NOTE: crediting requires Shopee Affiliate API (App ID + Secret).
AFFILIATE_CODE_SHOPEE=

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=false
