{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@suplilist/shared": ["../shared/dist/index.d.ts"],
      "@suplilist/shared/*": ["../shared/dist/*.d.ts"]
    },
    "noImplicitAny": false
  },
  "include": [
    "src/modules/**/*.ts",
    "src/app.ts",
    "src/server.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}
