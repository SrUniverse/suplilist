{
  "version": 2,
  "installCommand": "npm install --include=dev",
  "buildCommand": "npm run build -w @suplilist/shared && cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/cron/:path*", "destination": "/api/cron/:path*" },
    { "source": "/api/webhooks/:path*", "destination": "/api/webhooks/:path*" },
    { "source": "/api/:path*",      "destination": "/api/index" },
    { "source": "/:path*",          "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/outbox", "schedule": "0 0 * * *" },
    { "path": "/api/cron/audit",  "schedule": "0 6 * * *" },
    { "path": "/api/cron/purge",  "schedule": "0 2 * * *" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ]
}

